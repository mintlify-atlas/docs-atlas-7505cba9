  "keyFeatures": [
    "AI-powered failure classification (code issues vs product bugs)",
    "Multiple AI provider support (Claude, Gemini, Cursor)",
    "Async and sync analysis modes",
    "Jira integration with AI-powered relevance filtering",
    "HTML report generation with dark theme",
    "JUnit XML enrichment for pytest integration",
    "SQLite result storage and retrieval",
    "Webhook callbacks for async results"
  ],
  "publicApiSurface": [
    "POST /analyze - Submit Jenkins job for analysis",
    "POST /analyze?sync=true - Submit and wait for results",
    "POST /analyze-failures - Analyze raw test failures",
    "GET /results/{job_id} - Retrieve analysis results (JSON)",
    "GET /results/{job_id}.html - Retrieve HTML report",
    "GET /results - List recent analysis jobs",
    "GET /dashboard - View HTML dashboard",
    "GET /health - Health check endpoint"
  ]
